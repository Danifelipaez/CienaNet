# === Base de datos (Supabase) ===
# Nombres generados por la integración Vercel-Supabase — no renombrar, config.py los lee tal cual.
# Pooler de transacción (puerto 6543) — usado por la app en runtime (pgBouncer, sin prepared statements).
POSTGRES_PRISMA_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
# Conexión directa (puerto 5432) — usada SOLO por Alembic para migraciones.
POSTGRES_URL_NON_POOLING=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# === Supabase API ===
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# === Meta WhatsApp Cloud API ===
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# === IA / NLU (Google AI Studio / Gemini) ===
# API key de Google AI Studio (https://aistudio.google.com/apikey). Vacío = stub, sin IA.
AI_API_KEY=
# Id del modelo de AI Studio. Ajustar al id exacto cuando se confirme (p.ej. gemini-flash-3-lite).
AI_MODEL=gemini-flash-lite-latest
# Mensajes previos que se mandan como contexto en conversaciones de WhatsApp.
AI_HISTORY_TURNS=10

# === App ===
ENVIRONMENT=development
# Salt para hashear API keys de sensores: openssl rand -hex 32
SENSOR_API_KEY_SECRET=
# Clave para el endpoint /admin/* (protege registro de sensores): openssl rand -hex 32
ADMIN_API_KEY=change-me

# === Coordenadas Ciénaga Grande (no secretos, tienen default en config.py) ===
# Centroide real medido (ver docs/KNOWLEDGE_BASE.md #12)
CIENAGA_LAT=10.859056
CIENAGA_LON=-74.460611
